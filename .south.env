# ============================================================
# 料仓监控系统后端配置文件 (南厂)
# ============================================================
# 使用说明:
# 1. 部署南厂时将此文件重命名为 .env
# 2. 生产模式: MOCK_MODE=false
# 3. 重启服务使配置生效
# ============================================================

# ============================================================
# 1. 服务器配置
# ============================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8082
DEBUG=false

# ============================================================
# 2. 运行模式配置
# ============================================================
MOCK_MODE=false
ENABLE_POLLING=true
VERBOSE_POLLING_LOG=false

# PLC 轮询间隔(秒)
PLC_POLL_INTERVAL=0.5

# ============================================================
# 3. PLC 配置 (南厂 PLC)
# ============================================================
PLC_IP=192.168.50.234

# PLC_RACK: PLC 机架号
PLC_RACK=0

# PLC_SLOT: PLC 插槽号
PLC_SLOT=1

# PLC_TIMEOUT: PLC 连接超时时间(毫秒)
PLC_TIMEOUT=5000

# ============================================================
# 4. InfluxDB 配置
# ============================================================
# admin admin_password
# INFLUX_ORG: InfluxDB 组织名
INFLUX_ORG=clutchtech
# INFLUX_URL: InfluxDB 服务地址
INFLUX_URL=http://localhost:8086

# 南厂 Token (当前激活)
INFLUX_TOKEN=K0Sl1yPjUHiKJMN15ah76s4EfGpRVsa7pj0lbtn3Z0hagWmFWLoKSs57KnkGzd3LQEtfzBXBZNA2v5nP4hcDwQ==
INFLUX_BUCKET=hopper_south

# 北厂 Token (备用)
#INFLUX_TOKEN=YilKv7CWD3pUXoGAj5VmBAtQq1aQ0py5661vs0HIKGEWV5zKg01gLKOqvEJBcNXKgXwWI9iI-TpwPQHRSl86Mg==
#INFLUX_BUCKET=hopper_north

# 批量写入大小: 每累积 N 次轮询后写入一次 InfluxDB
# 当前 PLC_POLL_INTERVAL=0.5s, BATCH_WRITE_SIZE=12, 即每 6 秒写入一次
BATCH_WRITE_SIZE=12

# VIB_HIGH_PRECISION: 振动传感器精度模式
# true=高精度(V/100, D/10, HZ/10), false=低精度(直接使用原始值)
VIB_HIGH_PRECISION=true

# LOCAL_CACHE_PATH: 本地缓存文件路径(SQLite,InfluxDB 故障时降级使用)
LOCAL_CACHE_PATH=data/cache.db

# ============================================================
# 5. 配置文件路径
# ============================================================
CONFIG_DIR=configs
SENSORS_CONFIG_FILE=configs/sensors.yaml
DEVICES_CONFIG_FILE=configs/devices.yaml
